{
  "name": "market-intelligence-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "build:check": "tsc --noEmit && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "refresh": "node scripts/pipeline.mjs --all",
    "refresh:news": "node scripts/pipeline.mjs --news",
    "refresh:stocks": "node scripts/pipeline.mjs --stocks",
    "refresh:ratings": "node scripts/pipeline.mjs --ratings",
    "refresh:analyze": "node scripts/pipeline.mjs --news --analyze",
    "refresh:dry": "node scripts/pipeline.mjs --all --dry-run",
    "ingest-pdf": "node scripts/ingestPdf.mjs",
    "api": "node scripts/apiProxy.mjs",
    "seed": "node scripts/seed.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "better-sqlite3": "^12.6.2",
    "chart.js": "^4.5.1",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.35.2",
    "lucide-react": "^0.577.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.2.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^4.1.0"
  }
}
