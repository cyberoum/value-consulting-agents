{
  "name": "market-intelligence-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "build:check": "tsc --noEmit && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "refresh": "node scripts/pipeline.mjs --all",
    "refresh:news": "node scripts/pipeline.mjs --news",
    "refresh:stocks": "node scripts/pipeline.mjs --stocks",
    "refresh:ratings": "node scripts/pipeline.mjs --ratings",
    "refresh:analyze": "node scripts/pipeline.mjs --news --analyze",
    "refresh:contacts": "node scripts/pipeline.mjs --contacts",
    "refresh:signals": "node scripts/pipeline.mjs --signals",
    "refresh:full": "node scripts/pipeline.mjs --all --signals --contacts && node scripts/generateBundle.mjs",
    "refresh:dry": "node scripts/pipeline.mjs --all --dry-run",
    "profile-bank": "node scripts/fetchers/bankProfiler.mjs",
    "profile-all-skeleton": "node scripts/fetchers/bankProfiler.mjs && node scripts/generateBundle.mjs",
    "ingest-pdf": "node scripts/ingestPdf.mjs",
    "api": "node scripts/apiProxy.mjs",
    "seed": "node scripts/seed.mjs",
    "generate-bundle": "node scripts/generateBundle.mjs",
    "seed-and-bundle": "node scripts/seed.mjs && node scripts/generateBundle.mjs",
    "refresh-and-bundle": "node scripts/pipeline.mjs --all && node scripts/generateBundle.mjs",
    "validate-urls": "node scripts/validateSignalUrls.mjs",
    "validate-urls:fix": "node scripts/validateSignalUrls.mjs --fix",
    "generate-pulses": "node scripts/generatePulses.mjs",
    "generate-pulses:dry": "node scripts/generatePulses.mjs --dry-run",
    "extract-facts": "node scripts/extractMeetingFacts.mjs",
    "extract-facts:force": "node scripts/extractMeetingFacts.mjs --force",
    "extract-facts:dry": "node scripts/extractMeetingFacts.mjs --dry-run",
    "cross-reference": "node scripts/runCrossReference.mjs",
    "cross-reference:force": "node scripts/runCrossReference.mjs --force",
    "cross-reference:dry": "node scripts/runCrossReference.mjs --dry-run",
    "grade-sources": "node scripts/gradeSignalSources.mjs",
    "grade-sources:force": "node scripts/gradeSignalSources.mjs --force",
    "grade-sources:inspect": "node scripts/gradeSignalSources.mjs --inspect",
    "reclassify-signals": "node scripts/reclassifySignals.mjs",
    "reclassify-signals:dry": "node scripts/reclassifySignals.mjs --dry-run",
    "reclassify-signals:missing-fields": "node scripts/reclassifySignals.mjs --missing-fields",
    "route-signals": "node scripts/routeSignals.mjs",
    "route-signals:dry": "node scripts/routeSignals.mjs --dry-run",
    "harvest-nordic": "node scripts/harvestNordicSignals.mjs",
    "harvest-nordic:dry": "node scripts/harvestNordicSignals.mjs --dry-run",
    "pipeline:nordic": "node scripts/harvestNordicSignals.mjs && node scripts/reclassifySignals.mjs --only-stale && node scripts/routeSignals.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "better-sqlite3": "^12.6.2",
    "chart.js": "^4.5.1",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.35.2",
    "lucide-react": "^0.577.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.2.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^4.1.0"
  }
}
